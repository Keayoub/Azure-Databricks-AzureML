{
  "name": "AzureML-KeyVault-Integration-Test",
  "description": "Validates integration between Azure ML workspace and Azure Key Vault using managed identity from Databricks",
  "tasks": [
    {
      "task_key": "keyvault_integration_test",
      "description": "Run AzureML KeyVault integration notebook",
      "notebook_task": {
        "notebook_path": "/Workspace/tutorials/02-core-integration/Databricks_KeyVault_Integration_Test",
        "source": "WORKSPACE",
        "base_parameters": {
          "AZURE_SUBSCRIPTION_ID": "{{secrets/azureml-kv-scope/subscription-id}}",
          "AZURE_RESOURCE_GROUP": "{{secrets/azureml-kv-scope/resource-group}}",
          "AZUREML_WORKSPACE_NAME": "{{secrets/azureml-kv-scope/workspace-name}}",
          "KEY_VAULT_NAME": "{{secrets/azureml-kv-scope/keyvault-name}}",
          "DATABRICKS_SECRET_SCOPE": "azureml-kv-scope"
        }
      },
      "job_cluster_key": "keyvault_test_cluster",
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 30000,
      "retry_on_timeout": true
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "keyvault_test_cluster",
      "new_cluster": {
        "cluster_name": "",
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 0,
        "spark_conf": {
          "spark.databricks.cluster.profile": "singleNode",
          "spark.master": "local[*]"
        },
        "custom_tags": {
          "ResourceClass": "SingleNode",
          "Purpose": "IntegrationTest",
          "Service": "AzureML-KeyVault"
        },
        "spark_env_vars": {
          "PYSPARK_PYTHON": "/databricks/python3/bin/python3"
        },
        "enable_elastic_disk": true,
        "data_security_mode": "USER_ISOLATION",
        "runtime_engine": "STANDARD"
      }
    }
  ],
  "email_notifications": {
    "on_start": [],
    "on_success": [],
    "on_failure": [],
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "schedule": {
    "quartz_cron_expression": "0 0 9 ? * MON",
    "timezone_id": "UTC",
    "pause_status": "PAUSED"
  },
  "max_concurrent_runs": 1,
  "format": "MULTI_TASK",
  "tags": {
    "environment": "dev",
    "purpose": "integration-testing",
    "service": "azureml-keyvault"
  }
}
